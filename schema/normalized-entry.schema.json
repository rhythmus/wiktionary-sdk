      ]
    },
    "Pronunciation": {
      "type": "object",
      "properties": {
        "IPA": {
          "type": "string",
          "description": "International Phonetic Alphabet transcription."
        },
        "audio": {
          "type": "string",
          "description": "Raw Wikimedia Commons filename, e.g. 'El-γράφω.ogg'."
        },
        "audio_url": {
          "type": "string",
          "format": "uri",
          "description": "Resolved Wikimedia Commons download URL for the audio file."
        },
        "audio_details": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "format": "uri"
              },
              "label": {
                "type": "string",
                "description": "Regional label, e.g. 'UK', 'Netherlands'."
              },
              "filename": {
                "type": "string"
              }
            },
            "required": [
              "url",
              "filename"
            ]
          },
          "description": "Detailed audio resources with dialect/location labels."
        },
        "romanization": {
          "type": "string",
          "description": "Romanized form of the headword, e.g. 'gráfo' for γράφω."
        },
        "rhymes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Rhyming words or sounds."
        },
        "homophones": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Words that sound the same but have different meanings/spellings."
        }
      },
      "additionalProperties": false
    },
    "RelationConfidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "RelationSourceEvidence": {
      "type": "string",
      "enum": [
        "template_id",
        "section_scope",
        "qualifier_match",
        "heuristic"
      ]
    },
    "RichEntry": {
      "type": "object",
      "required": [
        "headword",
        "pos",
        "source"
      ],
      "properties": {
        "headword": {
          "type": "string"
        },
        "pos": {
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/LexemeType"
        },
        "form_of": {
          "$ref": "#/$defs/FormOf"
        },
        "morphology": {
          "type": "object",
          "additionalProperties": true
        },
        "headword_morphology": {
          "$ref": "#/$defs/HeadwordMorphology"
        },
        "pronunciation": {
          "$ref": "#/$defs/Pronunciation"
        },
        "hyphenation": {
          "$ref": "#/$defs/Hyphenation"
        },
        "etymology": {
          "$ref": "#/$defs/EtymologyData"
        },
        "senses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Sense"
          }
        },
        "relations": {
          "$ref": "#/$defs/SemanticRelations"
        },
        "relations_by_sense": {
          "$ref": "#/$defs/SemanticRelationsBySense"
        },
        "derived_terms": {
          "$ref": "#/$defs/SectionWithLinks"
        },
        "related_terms": {
          "$ref": "#/$defs/SectionWithLinks"
        },
        "descendants": {
          "$ref": "#/$defs/SectionWithLinks"
        },
        "usage_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "references": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "inflection_table": {
          "$ref": "#/$defs/InflectionTable"
        },
        "translations": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/TranslationItem"
            }
          }
        },
        "wikidata": {
          "$ref": "#/$defs/WikidataEnrichment"
        },
        "images": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Image filenames/URLs from the source lexeme (`library.richEntry`)."
        },
        "source": {
          "$ref": "#/$defs/WiktionarySource"
        }
      },
      "additionalProperties": true
    },
    "SectionLinkItem": {
      "type": "object",
      "required": [
        "term",
        "lang",
        "template",
        "raw"
      ],
      "properties": {
        "term": {
          "type": "string"
        },
        "lang": {
          "type": "string"
        },
        "gloss": {
          "type": "string"
        },
        "alt": {
          "type": "string"
        },
        "template": {
          "type": "string"
        },
        "raw": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "SectionWithLinks": {
      "type": "object",
      "required": [
        "raw_text",
        "items"
      ],
      "properties": {
        "raw_text": {
          "type": "string",
          "description": "Verbatim section content"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SectionLinkItem"
          }
        }
      },
      "additionalProperties": false
    },
    "SemanticRelation": {
      "type": "object",
      "required": [
        "term"
      ],
      "properties": {
        "term": {
          "type": "string"
        },
        "sense_id": {
          "type": "string",
          "description": "Explicit sense anchor from wikitext (template id= parameter)."
        },
        "qualifier": {
          "type": "string"
        },
        "source_evidence": {
          "$ref": "#/$defs/RelationSourceEvidence",
          "description": "How this relation was linked to a sense."
        },
        "confidence": {
          "$ref": "#/$defs/RelationConfidence",
          "description": "Confidence of the sense-to-relation link."
        },
        "matched_sense_id": {
          "type": "string",
          "description": "Sense ID this relation was resolved to (may differ from source sense_id when heuristic)."
        }
      },
      "additionalProperties": false
    },
    "SemanticRelations": {
      "type": "object",
      "properties": {
        "synonyms": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SemanticRelation"
          }
        },
        "antonyms": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SemanticRelation"
          }
        },
        "hypernyms": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SemanticRelation"
          }
        },
        "hyponyms": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SemanticRelation"
          }
        },
        "coordinate_terms": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SemanticRelation"
          },
          "description": "Peer-level terms (e.g. days of the week together)."
        },
        "holonyms": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SemanticRelation"
          },
          "description": "Wholes that contain this term as a part."
        },
        "meronyms": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SemanticRelation"
          },
          "description": "Parts that make up this term."
        },
        "troponyms": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SemanticRelation"
          },
          "description": "For verbs: manner-of-action subtypes."
        },
        "comeronyms": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SemanticRelation"
          },
          "description": "Terms in the same semantic field (complementary/contrastive); Wiktionary Comeronyms section."
        },
        "parasynonyms": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SemanticRelation"
          },
          "description": "Near-synonyms with distinct nuance; Wiktionary Parasynonyms section."
        },
        "collocations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SemanticRelation"
          },
          "description": "Typical word combinations; Wiktionary Collocations section."
        }
      },
      "additionalProperties": false
    },
    "SemanticRelationsBySense": {
      "type": "object",
      "description": "Sense-grouped projection of semantic relations. Keys are sense IDs (e.g. 'S1'); values contain only the relations linked to that sense.",
      "additionalProperties": {
        "$ref": "#/$defs/SemanticRelations"
      }
    },
    "Sense": {
      "type": "object",
      "required": [
        "id",
        "gloss"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique sense ID, e.g. 'S1', 'S1.1'"
        },
        "gloss": {
          "type": "string"
        },
        "gloss_raw": {
          "type": "string",
          "description": "Exact text after #/## before stripping"
        },
        "only_used_in": {
          "$ref": "#/$defs/OnlyUsedIn"
        },
        "qualifier": {
          "type": "string",
          "description": "Parenthetical qualifier after the main gloss, e.g. 'for traffic violations'."
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Register/style labels from {{lb}}, e.g. ['colloquial', 'figurative']."
        },
        "topics": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Topic domains from {{lb}}, e.g. ['law', 'computing']."
        },
        "examples": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "$ref": "#/$defs/Example"
              }
            ]
          }
        },
        "subsenses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Sense"
          }
        }
      },
      "additionalProperties": false
    },
    "SitelinkValue": {
      "type": "object",
      "required": [
        "site",
        "title"
      ],
      "properties": {
        "site": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false
    },
    "StoredTemplate": {
      "type": "object",
      "required": [
        "params",
        "raw"
      ],
      "properties": {
        "params": {
          "$ref": "#/$defs/TemplateParams"
        },
        "raw": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "StoredTemplateInstance": {
      "type": "object",
      "required": [
        "name",
        "raw",
        "params"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "raw": {
          "type": "string"
        },
        "params": {
          "$ref": "#/$defs/TemplateParams"
        },
        "start": {
          "type": "integer",
          "description": "Character offset in posBlockWikitext"
        },
        "end": {
          "type": "integer",
          "description": "Character offset in posBlockWikitext"
        },
        "line": {
          "type": "integer",
          "description": "1-based line number"
        }
      },
      "additionalProperties": false
    },
    "TemplateParams": {
      "type": "object",
      "required": [
        "positional",
        "named"
      ],
      "properties": {
        "positional": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "named": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "TranslationItem": {
      "type": "object",
      "required": [
        "term",
        "sense",
        "template",
        "raw",
        "params"
      ],
      "properties": {
        "term": {
          "type": "string",
          "description": "The translation term (authoritative)"
        },
        "gloss": {
          "type": "string",
          "description": "From explicit t= or gloss= only"
        },
        "transliteration": {
          "type": "string",
          "description": "From tr="
        },
        "gender": {
          "type": "string",
          "description": "From g="
        },
        "alt": {
          "type": "string",
          "description": "From alt="
        },
        "sense": {
          "type": [
            "string",
            "null"
          ]
        },
        "template": {
          "type": "string"
        },
        "raw": {
          "type": "string"
        },
        "params": {
          "description": "Template parameters verbatim; usually `TemplateParams`, occasionally a generic object from edge-case decoders.",
          "oneOf": [
            {
              "$ref": "#/$defs/TemplateParams"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "WikiLang": {
      "type": "string",
      "description": "BCP-47-style language code.",
      "examples": [
        "el",
        "grc",
        "en",
        "nl",
        "de",
        "fr"
      ]
    },
    "WikidataDisambiguation": {
      "type": "object",
      "required": [
        "candidates"
      ],
      "properties": {
        "candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DisambiguationCandidate"
          }
        },
        "sense_matches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DisambiguationSenseMatch"
          }
        }
      },
      "additionalProperties": false
    },
    "WikidataEnrichment": {
      "type": "object",
      "required": [
        "qid"
      ],
      "properties": {
        "qid": {
          "type": "string",
          "pattern": "^Q\\d+$"
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/LabelValue"
          }
        },
        "descriptions": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/LabelValue"
          }
        },
        "sitelinks": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/SitelinkValue"
          }
        },
        "media": {
          "$ref": "#/$defs/WikidataMedia"
        },
        "instance_of": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^Q\\d+$"
          },
          "description": "Wikidata P31 'Instance Of' claims."
        },
        "subclass_of": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^Q\\d+$"
          },
          "description": "Wikidata P279 'Subclass Of' claims."
        },
        "disambiguation": {
          "$ref": "#/$defs/WikidataDisambiguation",
          "description": "Candidate targets and sense hints when qid is a disambiguation item."
        },
        "wikidata_error": {
          "type": "string",
          "description": "Optional diagnostic when Wikidata enrichment failed."
        }
      },
      "additionalProperties": false
    },
    "WikidataMedia": {
      "type": "object",
      "properties": {
        "P18": {
          "type": "string"
        },
        "commons_file": {
          "type": "string"
        },
        "thumbnail": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false
    },
    "WiktionaryLanglink": {
      "type": "object",
      "required": [
        "lang",
        "title"
      ],
      "properties": {
        "lang": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "WiktionarySource": {
      "type": "object",
      "required": [
        "site",
        "title",
        "language_section",
        "etymology_index",
        "pos_heading"
      ],
      "properties": {
        "site": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "language_section": {
          "type": "string"
        },
        "etymology_index": {
          "type": "integer",
          "minimum": 0
        },
        "pos_heading": {
          "type": "string"
        },
        "revision_id": {
          "type": "integer",
          "description": "MediaWiki revision ID at time of fetch. Use for reproducibility/cache-busting."
        },
        "last_modified": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of the last page edit from the MediaWiki API when available; some sites return timestamps that are not strict RFC 3339.",
          "examples": [
            "2026-03-28T17:18:53Z"
          ]
        },
        "pageid": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Numeric page ID from the MediaWiki API."
        }
      },
      "additionalProperties": false
    },
    "schemaVersion": {
      "type": "string",
      "description": "Semantic version of this output schema. Bump MAJOR for breaking shape changes, MINOR for additive fields, PATCH for documentation-only corrections.",
      "examples": [
        "3.3.0",
        "3.2.0",
        "3.0.0"
      ]
    }
  }
}
