        "participle",
        "particle",
        "phrase",
        "postposition",
        "prefix",
        "preposition",
        "prepositional_phrase",
        "pronoun",
        "proper_noun",
        "proverb",
        "punctuation",
        "subordinating_conjunction",
        "suffix",
        "symbol",
        "transitive_verb",
        "unknown",
        "v_unspec",
        "v1",
        "v1_s",
        "v2a_s",
        "v2b_k",
        "v2b_s",
        "v2d_k",
        "v2d_s",
        "v2g_k",
        "v2g_s",
        "v2h_k",
