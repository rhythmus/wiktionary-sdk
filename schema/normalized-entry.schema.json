        "t_gloss": {
          "type": "string",
          "description": "Optional gloss from |t= / |4="
        },
        "raw": {
          "type": "string",
          "description": "Verbatim {{only used in|…}} template"
        }
      },
      "additionalProperties": false
    },
    "PageMetadataInfo": {
      "type": "object",
      "description": "Subset of MediaWiki `prop=info` fields mirrored on `Lexeme.metadata` and `FetchResult.metadata.info`.",
      "properties": {
        "last_modified": {
          "type": "string",
          "format": "date-time",
