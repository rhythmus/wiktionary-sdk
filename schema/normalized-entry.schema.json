{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/rhythmus/wiktionary-sdk/schema/normalized-entry.schema.json",
  "title": "Wiktionary SDK Normalized Output",
  "description": "JSON Schema for the wiktionary-sdk engine output (FetchResult and Lexeme types). v3.3.0.",
  "type": "object",
  "properties": {
    "schema_version": {
      "$ref": "#/$defs/schemaVersion"
    },
    "rawLanguageBlock": {
      "type": "string"
    },
    "lexemes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Lexeme"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "debug": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/DecoderDebugEvent"
        }
      },
      "description": "Detailed trace of decoder matches per lexeme (`debugDecoders: true`). Outer array aligns with `lexemes` order."
    },
    "metadata": {
      "type": "object",
      "description": "Page-level metadata attached to the FetchResult (whole page, not per lexeme).",
      "properties": {
        "categories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "langlinks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/WiktionaryLanglink"
          }
        },
        "info": {
          "$ref": "#/$defs/PageMetadataInfo"
        }
      },
      "additionalProperties": true
    }
  },
  "required": [
    "schema_version",
    "rawLanguageBlock",
    "lexemes",
    "notes"
  ],
  "$defs": {
    "AlternativeForm": {
      "type": "object",
      "required": [
        "term",
        "raw"
      ],
      "properties": {
        "term": {
          "type": "string"
        },
        "qualifier": {
          "type": "string",
          "description": "Optional label, e.g. 'colloquial', 'archaic'."
        },
        "raw": {
          "type": "string",
          "description": "Verbatim wikitext line."
        },
        "type": {
          "type": "string",
          "description": "Variant kind when decoded, e.g. 'polytonic', 'archaic'."
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Register/style labels for the variant, e.g. ['rare', 'poetic']."
        }
      },
      "additionalProperties": false
    },
    "ConjugateCriteria": {
      "type": "object",
      "description": "Optional verb conjugation filters (`src/morphology.ts`).",
      "properties": {
        "person": {
          "type": "string",
          "enum": [
            "1",
            "2",
            "3"
          ]
        },
        "number": {
          "type": "string",
          "enum": [
            "singular",
            "plural"
          ]
        },
        "voice": {
          "type": "string",
          "enum": [
            "active",
            "passive"
          ]
        },
        "mood": {
          "type": "string",
          "enum": [
            "indicative",
            "subjunctive",
            "imperative"
          ]
        },
        "tense": {
          "type": "string",
          "enum": [
            "present",
            "past",
            "future",
            "perfect",
            "pluperfect",
            "future perfect"
          ]
        },
        "aspect": {
          "type": "string",
          "enum": [
            "imperfective",
            "perfective"
          ]
        }
      },
      "additionalProperties": false
    },
    "DeclineCriteria": {
      "type": "object",
      "description": "Optional nominal declension filters (`src/morphology.ts`).",
      "properties": {
        "case": {
          "type": "string",
          "enum": [
            "nominative",
            "genitive",
            "accusative",
            "vocative"
          ]
        },
        "number": {
          "type": "string",
          "enum": [
            "singular",
            "plural"
          ]
        },
        "gender": {
          "type": "string",
          "enum": [
            "masculine",
            "feminine",
            "neuter"
          ]
        }
      },
      "additionalProperties": false
    },
    "DecoderDebugEvent": {
      "type": "object",
      "required": [
        "decoderId",
        "matchedTemplates",
        "fieldsProduced"
      ],
      "properties": {
        "decoderId": {
          "type": "string"
        },
        "matchedTemplates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MatchedTemplateRef"
          }
        },
        "fieldsProduced": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "DisambiguationCandidate": {
      "type": "object",
      "required": [
        "title",
        "qid"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "qid": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^Q\\d+$"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false
    },
    "DisambiguationSenseMatch": {
      "type": "object",
      "required": [
        "sense_id",
        "candidate_qid",
        "candidate_title",
        "score"
      ],
      "properties": {
        "sense_id": {
          "type": "string"
        },
        "candidate_qid": {
          "type": "string",
          "pattern": "^Q\\d+$"
        },
        "candidate_title": {
          "type": "string"
        },
        "score": {
          "type": "number"
        },
        "match_reasons": {
          "type": "object",
          "properties": {
            "title_token_hits": {
              "type": "integer",
              "minimum": 0
            },
            "aux_token_hits": {
              "type": "integer",
              "minimum": 0
            },
            "title_phrase_hit": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "EtymologyData": {
      "type": "object",
      "properties": {
        "chain": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EtymologyLink"
          },
          "description": "Ordered ancestry chain: inherited (inh), derived (der), borrowed (bor) links."
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EtymologyLink"
          },
          "description": "Deprecated alias for `chain`. Prefer `chain` for new data."
        },
        "cognates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EtymologyLink"
          },
          "description": "Cognate forms in other languages (from {{cog}} templates), distinct from the ancestry chain."
        },
        "raw_text": {
          "type": "string",
          "description": "Full human-readable prose of the etymology section, wikimarkup stripped."
        }
      },
      "additionalProperties": false
    },
    "EtymologyLink": {
      "type": "object",
      "required": [
        "template",
        "relation",
        "source_lang",
        "raw"
      ],
      "properties": {
        "template": {
          "type": "string",
          "description": "Template name, e.g. 'inh', 'der', 'bor', 'cog'"
        },
        "relation": {
          "type": "string",
          "description": "The semantic relation between the target and source language forms. Typically 'inherited', 'borrowed', 'derived', or 'cognate'.",
          "examples": [
            "inherited",
            "borrowed",
            "derived",
            "cognate"
          ]
        },
        "source_lang": {
          "type": "string"
        },
        "source_lang_name": {
          "type": "string"
        },
        "term": {
          "type": "string"
        },
        "gloss": {
          "type": "string"
        },
        "raw": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "Example": {
      "type": "object",
      "properties": {
        "text": {
          "type": "string"
        },
        "translation": {
          "type": "string"
        },
        "transliteration": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "year": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "raw": {
          "type": "string"
        }
      },
      "required": [
        "text"
      ]
    },
    "FormOf": {
      "type": "object",
      "required": [
        "template",
        "lang",
        "tags",
        "named"
      ],
      "properties": {
        "template": {
          "type": "string"
        },
        "lemma": {
          "type": [
            "string",
            "null"
          ]
        },
        "lang": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Abbreviated inflection / variant tags from form-of templates (e.g. person, number, tense); see `parseMorphologyTags` in `src/morphology.ts` for common tag vocabulary."
        },
        "subclass": {
          "type": "string",
          "description": "The specific subclass of form-of (e.g. 'misspelling', 'abbreviation', 'plural')."
        },
        "label": {
          "type": "string",
          "description": "Human-readable label rendered from the tag array, e.g. '1st pers. singular perfective past'."
        },
        "named": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "display_morph_lines": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Inflection lines from MediaWiki parse of the definition (e.g. {{ll-verb|noun|adj form of}} Lua HTML)."
        },
        "display_morph_lines_source": {
          "type": "string",
          "enum": [
            "mediawiki_parse"
          ]
        }
      },
      "additionalProperties": false
    },
    "GrammarTraits": {
      "type": "object",
      "description": "Merged conjugation + declension criteria (`GrammarTraits` in `src/morphology.ts`).",
      "properties": {
        "person": {
          "type": "string",
          "enum": [
            "1",
            "2",
            "3"
          ]
        },
        "number": {
          "type": "string",
          "enum": [
            "singular",
            "plural"
          ]
        },
        "voice": {
          "type": "string",
          "enum": [
            "active",
            "passive"
          ]
        },
        "mood": {
          "type": "string",
          "enum": [
            "indicative",
            "subjunctive",
            "imperative"
          ]
        },
        "tense": {
          "type": "string",
          "enum": [
            "present",
            "past",
            "future",
            "perfect",
            "pluperfect",
            "future perfect"
          ]
        },
        "aspect": {
          "type": "string",
          "enum": [
            "imperfective",
            "perfective"
          ]
        },
        "case": {
          "type": "string",
          "enum": [
            "nominative",
            "genitive",
            "accusative",
            "vocative"
          ]
        },
        "gender": {
          "type": "string",
          "enum": [
            "masculine",
            "feminine",
            "neuter"
          ]
        }
      },
      "additionalProperties": false
    },
    "GroupedLexemeMapValue": {
      "type": "object",
      "description": "Value shape stored under `GroupedLexemeResults.lexemes[lexeme_id]` (`src/convenience/grouped-results.ts`).",
      "required": [
        "language",
        "pos",
        "etymology_index",
        "value"
      ],
      "properties": {
        "language": {
          "type": "string"
        },
        "pos": {
          "type": "string"
        },
        "etymology_index": {
          "type": "integer",
          "minimum": 0
        },
        "value": {}
      },
      "additionalProperties": false
    },
    "HeadwordMorphology": {
      "type": "object",
      "description": "Grammatical traits extracted from the headword template (el-verb, el-noun, etc.).",
      "properties": {
        "transitivity": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "transitive",
            "intransitive",
            "both",
            null
          ],
          "description": "For verbs: whether the verb takes a direct object."
        },
        "gender": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "masculine",
            "feminine",
            "neuter",
            null
          ],
          "description": "For nouns/adjectives: grammatical gender."
        },
        "principal_parts": {
          "type": "object",
          "description": "Paradigm slots from headword / inflection-stem decoders (e.g. `present`, `aorist_active`, `simple_past`, `stem` from Greek `el-noun-stems` / `el-verb-stems`). Keys are template-driven, not a closed set.",
          "additionalProperties": {
            "type": "string"
          }
        },
        "aspect": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "perfective",
            "imperfective",
            null
          ],
          "description": "For verbs: aspectual trait."
        },
        "voice": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "active",
            "passive",
            "mediopassive",
            null
          ],
          "description": "For verbs: grammatical voice."
        }
      },
      "additionalProperties": false
    },
    "Hyphenation": {
      "type": "object",
      "required": [
        "raw"
      ],
      "properties": {
        "syllables": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "raw": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "InflectionTable": {
      "type": "object",
      "description": "A hierarchical representation of a grammatical paradigm. Keys are dimensions (e.g. 'mood', 'tense'), values are either strings, arrays of strings, or nested InflectionTable objects.",
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          {
            "$ref": "#/$defs/InflectionTable"
          }
        ]
      }
    },
    "LabelValue": {
      "type": "object",
      "required": [
        "language",
        "value"
      ],
      "properties": {
        "language": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "Lexeme": {
      "type": "object",
      "required": [
        "id",
        "language",
        "query",
        "type",
        "form",
        "etymology_index",
        "part_of_speech_heading",
        "lexicographic_section",
        "lexicographic_family",
        "templates",
        "source"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable lexeme id, typically `{lang}:{pageTitle}#E{etymology_index}#{section_slug}#{LexemeType}` (see engine output).",
          "examples": [
            "el:γράφω#E1#verb#LEXEME"
          ]
        },
        "language": {
          "$ref": "#/$defs/WikiLang"
        },
        "query": {
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/LexemeType"
        },
        "form": {
          "type": "string"
        },
        "etymology_index": {
          "type": "integer",
          "minimum": 0
        },
        "part_of_speech_heading": {
          "type": "string"
        },
        "lexicographic_section": {
          "type": "string",
          "description": "Stable slug for the section kind. Registered headings use slugs listed in `$defs.LexicographicSectionSlug`; unregistered headings use a derived slug from `fallbackLexicographicFromHeading`."
        },
        "lexicographic_family": {
          "$ref": "#/$defs/LexicographicFamily"
        },
        "part_of_speech": {
          "description": "Strict grammatical PoS when applicable; null for morphemes, symbols, phraseology, etc.",
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/PartOfSpeech"
            }
          ]
        },
        "pronunciation": {
          "$ref": "#/$defs/Pronunciation"
        },
        "hyphenation": {
          "$ref": "#/$defs/Hyphenation"
        },
        "form_of": {
          "$ref": "#/$defs/FormOf"
        },
        "translations": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/TranslationItem"
            }
          }
        },
        "templates": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/StoredTemplate"
            }
          }
        },
        "templates_all": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/StoredTemplateInstance"
          },
          "description": "Templates in document order with optional location metadata"
        },
        "senses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Sense"
          }
        },
        "semantic_relations": {
          "$ref": "#/$defs/SemanticRelations"
        },
        "semantic_relations_by_sense": {
          "$ref": "#/$defs/SemanticRelationsBySense"
        },
        "etymology": {
          "$ref": "#/$defs/EtymologyData"
        },
        "derived_terms": {
          "$ref": "#/$defs/SectionWithLinks"
        },
        "related_terms": {
          "$ref": "#/$defs/SectionWithLinks"
        },
        "descendants": {
          "$ref": "#/$defs/SectionWithLinks"
        },
        "usage_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "headword_morphology": {
          "$ref": "#/$defs/HeadwordMorphology"
        },
        "alternative_forms": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AlternativeForm"
          },
          "description": "Entries from the ====Alternative forms==== section."
        },
        "see_also": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Terms from the ====See also==== section."
        },
        "anagrams": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Anagrams of this word from the ====Anagrams==== section."
        },
        "references": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Content from the ====References==== section."
        },
        "inflection_table_ref": {
          "type": "object",
          "properties": {
            "template_name": {
              "type": "string"
            },
            "raw": {
              "type": "string"
            }
          },
          "required": [
            "template_name",
            "raw"
          ],
          "additionalProperties": false,
          "description": "Reference to the inflection template used."
        },
        "external_links": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          },
          "description": "All external links extracted from the page."
        },
        "page_links": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "All Wiktionary page titles linked from this article."
        },
        "images": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of image filenames/URLs found on the page."
        },
        "wikidata": {
          "$ref": "#/$defs/WikidataEnrichment"
        },
        "resolved_for_query": {
          "type": "string"
        },
        "lemma_triggered_by_lexeme_id": {
          "type": "string"
        },
        "preferred": {
          "type": "boolean"
        },
        "source": {
          "type": "object",
          "required": [
            "wiktionary"
          ],
          "properties": {
            "wiktionary": {
              "$ref": "#/$defs/WiktionarySource"
            }
          },
          "additionalProperties": false
        },
        "categories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Wiktionary categories filtered to this language section."
        },
        "langlinks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/WiktionaryLanglink"
          },
          "description": "Links to the same term in other Wiktionary language editions."
        },
        "metadata": {
          "$ref": "#/$defs/PageMetadataInfo"
        }
      },
      "additionalProperties": true
    },
    "LexemeResult": {
      "type": "object",
      "description": "Tagged per-lexeme row from `mapLexemes` and other `src/convenience/` helpers.",
      "required": [
        "lexeme_id",
        "language",
        "pos",
        "value"
      ],
      "properties": {
        "lexeme_id": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "pos": {
          "type": "string"
        },
        "etymology_index": {
          "type": "integer",
          "minimum": 0
        },
        "value": {}
      },
      "additionalProperties": false
    },
    "LexemeType": {
      "type": "string",
      "enum": [
        "LEXEME",
        "INFLECTED_FORM",
        "FORM_OF"
      ],
      "description": "Discriminator for the kind of lexeme."
    },
    "LexicographicFamily": {
      "type": "string",
      "description": "Taxonomic bucket for the lexeme-class section (see `src/lexicographic-headings.ts`).",
      "enum": [
        "pos",
        "morpheme",
        "symbol",
        "character",
        "phraseology",
        "numeral_kind",
        "other",
        "disallowed_attested"
      ]
    },
    "LexicographicSectionSlug": {
      "type": "string",
      "description": "Known `section_slug` values from `src/lexicographic-headings.ts`. `Lexeme.lexicographic_section` may also be any other string when `fallbackLexicographicFromHeading` derives a slug from an unregistered heading.",
      "enum": [
        "abbreviation",
        "acronym",
        "adjective",
        "adposition",
        "adverb",
        "affix",
        "ambiposition",
        "article",
        "cardinal_numeral",
        "cardinal_number",
        "character",
        "circumfix",
        "circumposition",
        "classifier",
        "clitic",
        "combining_form",
        "conjunction",
        "contraction",
        "counter",
        "determinative",
        "determiner",
        "diacritical_mark",
        "gerund",
        "han_character",
        "hanja",
        "hanzi",
        "idiom",
        "ideophone",
        "infix",
        "initialism",
        "interfix",
        "interjection",
        "kanji",
        "letter",
        "ligature",
        "logogram",
        "noun",
        "numeral",
        "number",
        "ordinal_numeral",
        "ordinal_number",
        "particle",
        "participle",
        "phrase",
        "phrasebook",
        "postposition",
        "preposition",
        "prepositional_phrase",
        "prefix",
        "pronoun",
        "proper_noun",
        "proverb",
        "punctuation_mark",
        "root",
        "romanization",
        "suffix",
        "syllable",
        "symbol",
        "verb"
      ]
    },
    "MatchedTemplateRef": {
      "type": "object",
      "required": [
        "raw",
        "name"
      ],
      "properties": {
        "raw": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "OnlyUsedIn": {
      "type": "object",
      "required": [
        "lang",
        "terms",
        "raw"
      ],
      "properties": {
        "lang": {
          "type": "string",
          "description": "Language code of the linked expression(s)"
        },
        "terms": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Fixed expression(s) from |2= (comma-separated in wikitext)"
