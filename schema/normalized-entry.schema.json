{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/rhythmus/wiktionary-sdk/schema/normalized-entry.schema.json",
  "title": "Wiktionary SDK Normalized Output",
  "description": "JSON Schema for the wiktionary-sdk engine output (FetchResult and Lexeme types). v3.2.0.",
  "type": "object",
  "$defs": {
    "schemaVersion": {
      "type": "string",
      "description": "Semantic version of this output schema. Bump MAJOR for breaking shape changes, MINOR for additive fields, PATCH for documentation-only corrections.",
      "examples": ["3.0.0", "2.0.0"]
    },
    "WikiLang": {
      "type": "string",
      "description": "BCP-47-style language code.",
      "examples": ["el", "grc", "en", "nl", "de", "fr"]
    },
    "LexemeType": {
      "type": "string",
      "enum": ["LEXEME", "INFLECTED_FORM", "FORM_OF"],
      "description": "Discriminator for the kind of lexeme."
    },
    "LexicographicFamily": {
      "type": "string",
      "description": "Taxonomic bucket for the lexeme-class section (see `src/lexicographic-headings.ts`).",
      "enum": [
        "pos",
        "morpheme",
        "symbol",
        "character",
        "phraseology",
        "numeral_kind",
        "other",
        "disallowed_attested"
      ]
    },
    "PartOfSpeech": {
      "type": "string",
      "description": "Part-of-speech slug (`Lexeme.part_of_speech`): en.wiktionary strict headings plus ODict-aligned tags (https://www.odict.org/docs/reference/pos), snake_case; Japanese ODict codes use underscores for hyphens. Non-PoS sections may use `lexicographic_section` with null `part_of_speech`. Canonical list: `PART_OF_SPEECH_VALUES` in `src/types.ts`.",
      "enum": [
        "abbreviation",
        "adfix",
        "adj_f",
        "adj_ix",
        "adj_kari",
        "adj_ku",
        "adj_na",
        "adj_nari",
        "adj_no",
        "adj_pn",
        "adj_shiku",
        "adj_t",
        "adjective",
        "adjective_phrase",
        "adv_to",
        "adverb",
        "adverbial_phrase",
        "affix",
        "article",
        "auxiliary",
        "auxiliary_adjective",
        "auxiliary_verb",
        "character",
        "circumfix",
        "conjunction",
        "contraction",
        "coordinating_conjunction",
        "copula",
        "counter",
        "determiner",
        "expression",
        "infix",
        "interfix",
        "interjection",
        "intransitive_verb",
        "n_adv",
        "n_pref",
        "n_suf",
        "n_t",
        "name",
        "noun",
        "numeral",
        "numeric",
        "participle",
        "particle",
        "phrase",
        "postposition",
        "prefix",
        "preposition",
        "prepositional_phrase",
        "pronoun",
        "proper_noun",
        "proverb",
        "punctuation",
        "subordinating_conjunction",
        "suffix",
        "symbol",
        "transitive_verb",
        "unknown",
        "v_unspec",
        "v1",
        "v1_s",
        "v2a_s",
        "v2b_k",
        "v2b_s",
        "v2d_k",
        "v2d_s",
        "v2g_k",
        "v2g_s",
        "v2h_k",
        "v2h_s",
        "v2k_k",
        "v2k_s",
        "v2m_k",
        "v2m_s",
        "v2n_s",
        "v2r_k",
        "v2r_s",
        "v2s_s",
        "v2t_k",
        "v2t_s",
        "v2w_s",
        "v2y_k",
        "v2y_s",
        "v2z_s",
        "v4b",
        "v4g",
        "v4h",
        "v4k",
        "v4m",
        "v4n",
        "v4r",
        "v4s",
        "v4t",
        "v5aru",
        "v5b",
        "v5g",
        "v5k",
        "v5k_s",
        "v5m",
        "v5n",
        "v5r",
        "v5r_i",
        "v5s",
        "v5t",
        "v5u",
        "v5u_s",
        "v5uru",
        "verb",
        "vk",
        "vn",
        "vr",
        "vs",
        "vs_c",
        "vs_i",
        "vs_s",
        "vz"
      ]
    },
    "Pronunciation": {
      "type": "object",
      "properties": {
        "IPA": { "type": "string", "description": "International Phonetic Alphabet transcription." },
        "audio": { "type": "string", "description": "Raw Wikimedia Commons filename, e.g. 'El-γράφω.ogg'." },
        "audio_url": {
          "type": "string",
          "format": "uri",
          "description": "Resolved Wikimedia Commons download URL for the audio file."
        },
        "audio_details": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": { "type": "string", "format": "uri" },
              "label": { "type": "string", "description": "Regional label, e.g. 'UK', 'Netherlands'." },
              "filename": { "type": "string" }
            },
            "required": ["url", "filename"]
          },
          "description": "Detailed audio resources with dialect/location labels."
        },
        "romanization": {
          "type": "string",
          "description": "Romanized form of the headword, e.g. 'gráfo' for γράφω."
        },
        "rhymes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Rhyming words or sounds."
        },
        "homophones": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Words that sound the same but have different meanings/spellings."
        }
      },
      "additionalProperties": false
    },
    "Hyphenation": {
      "type": "object",
      "required": ["raw"],
      "properties": {
        "syllables": {
          "type": "array",
          "items": { "type": "string" }
        },
        "raw": { "type": "string" }
      },
      "additionalProperties": false
    },
    "WiktionarySource": {
      "type": "object",
      "required": ["site", "title", "language_section", "etymology_index", "pos_heading"],
      "properties": {
        "site": { "type": "string" },
        "title": { "type": "string" },
        "language_section": { "type": "string" },
        "etymology_index": { "type": "integer", "minimum": 0 },
        "pos_heading": { "type": "string" },
        "revision_id": {
          "type": "integer",
          "description": "MediaWiki revision ID at time of fetch. Use for reproducibility/cache-busting."
        },
        "last_modified": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of the last page edit."
        },
        "pageid": {
          "type": ["integer", "null"],
          "description": "Numeric page ID from the MediaWiki API."
        }
      },
      "additionalProperties": false
    },
    "WikidataMedia": {
      "type": "object",
      "properties": {
        "P18": { "type": "string" },
        "commons_file": { "type": "string" },
        "thumbnail": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "LabelValue": {
      "type": "object",
      "required": ["language", "value"],
      "properties": {
        "language": { "type": "string" },
        "value": { "type": "string" }
      },
      "additionalProperties": false
    },
    "SitelinkValue": {
      "type": "object",
      "required": ["site", "title"],
      "properties": {
        "site": { "type": "string" },
        "title": { "type": "string" },
        "url": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "WikidataEnrichment": {
      "type": "object",
      "required": ["qid"],
      "properties": {
        "qid": { "type": "string", "pattern": "^Q\\d+$" },
        "labels": { "type": "object", "additionalProperties": { "$ref": "#/$defs/LabelValue" } },
        "descriptions": { "type": "object", "additionalProperties": { "$ref": "#/$defs/LabelValue" } },
        "sitelinks": { "type": "object", "additionalProperties": { "$ref": "#/$defs/SitelinkValue" } },
        "media": { "$ref": "#/$defs/WikidataMedia" },
        "instance_of": {
          "type": "array",
          "items": { "type": "string", "pattern": "^Q\\d+$" },
          "description": "Wikidata P31 'Instance Of' claims."
        },
        "subclass_of": {
          "type": "array",
          "items": { "type": "string", "pattern": "^Q\\d+$" },
          "description": "Wikidata P279 'Subclass Of' claims."
        },
        "wikidata_error": {
          "type": "string",
          "description": "Optional diagnostic when Wikidata enrichment failed."
        }
      },
      "additionalProperties": false
    },
    "Example": {
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "translation": { "type": "string" },
        "transliteration": { "type": "string" },
        "author": { "type": "string" },
        "year": { "type": "string" },
        "source": { "type": "string" },
        "raw": { "type": "string" }
      },
      "required": ["text"]
    },
    "TemplateParams": {
      "type": "object",
      "required": ["positional", "named"],
      "properties": {
        "positional": { "type": "array", "items": { "type": "string" } },
        "named": { "type": "object", "additionalProperties": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "StoredTemplate": {
      "type": "object",
      "required": ["params", "raw"],
      "properties": {
        "params": { "$ref": "#/$defs/TemplateParams" },
        "raw": { "type": "string" }
      },
      "additionalProperties": false
    },
    "StoredTemplateInstance": {
      "type": "object",
      "required": ["name", "raw", "params"],
      "properties": {
        "name": { "type": "string" },
        "raw": { "type": "string" },
        "params": { "$ref": "#/$defs/TemplateParams" },
        "start": { "type": "integer", "description": "Character offset in posBlockWikitext" },
        "end": { "type": "integer", "description": "Character offset in posBlockWikitext" },
        "line": { "type": "integer", "description": "1-based line number" }
      },
      "additionalProperties": false
    },
    "FormOf": {
      "type": "object",
      "required": ["template", "lang", "tags", "named"],
      "properties": {
        "template": { "type": "string" },
        "lemma": { "type": ["string", "null"] },
        "lang": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "subclass": {
          "type": "string",
          "description": "The specific subclass of form-of (e.g. 'misspelling', 'abbreviation', 'plural')."
        },
        "label": {
          "type": "string",
          "description": "Human-readable label rendered from the tag array, e.g. '1st pers. singular perfective past'."
        },
        "named": { "type": "object", "additionalProperties": { "type": "string" } },
        "display_morph_lines": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Inflection lines from MediaWiki parse of the definition (e.g. {{ll-verb|noun|adj form of}} Lua HTML)."
        },
        "display_morph_lines_source": {
          "type": "string",
          "enum": ["mediawiki_parse"]
        }
      },
      "additionalProperties": false
    },
    "TranslationItem": {
      "type": "object",
      "required": ["term", "sense", "template", "raw", "params"],
      "properties": {
        "term": { "type": "string", "description": "The translation term (authoritative)" },
        "gloss": { "type": "string", "description": "From explicit t= or gloss= only" },
        "transliteration": { "type": "string", "description": "From tr=" },
        "gender": { "type": "string", "description": "From g=" },
        "alt": { "type": "string", "description": "From alt=" },
        "sense": { "type": ["string", "null"] },
        "template": { "type": "string" },
        "raw": { "type": "string" },
        "params": {}
      },
      "additionalProperties": false
    },
    "HeadwordMorphology": {
      "type": "object",
      "description": "Grammatical traits extracted from the headword template (el-verb, el-noun, etc.).",
      "properties": {
        "transitivity": {
          "type": ["string", "null"],
          "enum": ["transitive", "intransitive", "both", null],
          "description": "For verbs: whether the verb takes a direct object."
        },
        "gender": {
          "type": ["string", "null"],
          "enum": ["masculine", "feminine", "neuter", null],
          "description": "For nouns/adjectives: grammatical gender."
        },
        "principal_parts": {
          "type": "object",
          "description": "For verbs: key paradigm forms keyed by slot name (simple_past, future_active, present_passive, …).",
          "additionalProperties": { "type": "string" }
        },
        "aspect": {
          "type": ["string", "null"],
          "enum": ["perfective", "imperfective", null],
          "description": "For verbs: aspectual trait."
        },
        "voice": {
          "type": ["string", "null"],
          "enum": ["active", "passive", "mediopassive", null],
          "description": "For verbs: grammatical voice."
        }
      },
      "additionalProperties": false
    },
    "AlternativeForm": {
      "type": "object",
      "required": ["term", "raw"],
      "properties": {
        "term": { "type": "string" },
        "qualifier": { "type": "string", "description": "Optional label, e.g. 'colloquial', 'archaic'." },
        "raw": { "type": "string", "description": "Verbatim wikitext line." }
      },
      "additionalProperties": false
    },
    "OnlyUsedIn": {
      "type": "object",
      "required": ["lang", "terms", "raw"],
      "properties": {
        "lang": { "type": "string", "description": "Language code of the linked expression(s)" },
        "terms": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Fixed expression(s) from |2= (comma-separated in wikitext)"
        },
        "t_gloss": { "type": "string", "description": "Optional gloss from |t= / |4=" },
        "raw": { "type": "string", "description": "Verbatim {{only used in|…}} template" }
      },
      "additionalProperties": false
    },
    "Sense": {
      "type": "object",
      "required": ["id", "gloss"],
      "properties": {
        "id": { "type": "string", "description": "Unique sense ID, e.g. 'S1', 'S1.1'" },
        "gloss": { "type": "string" },
        "gloss_raw": { "type": "string", "description": "Exact text after #/## before stripping" },
        "only_used_in": { "$ref": "#/$defs/OnlyUsedIn" },
        "qualifier": {
          "type": "string",
          "description": "Parenthetical qualifier after the main gloss, e.g. 'for traffic violations'."
        },
        "labels": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Register/style labels from {{lb}}, e.g. ['colloquial', 'figurative']."
        },
        "topics": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Topic domains from {{lb}}, e.g. ['law', 'computing']."
        },
        "examples": {
          "type": "array",
          "items": {
            "anyOf": [
              { "type": "string" },
              { "$ref": "#/$defs/Example" }
            ]
          }
        },
        "subsenses": { "type": "array", "items": { "$ref": "#/$defs/Sense" } }
      },
      "additionalProperties": false
    },
    "SemanticRelation": {
      "type": "object",
      "required": ["term"],
      "properties": {
        "term": { "type": "string" },
        "sense_id": { "type": "string" },
        "qualifier": { "type": "string" }
      },
      "additionalProperties": false
    },
    "SemanticRelations": {
      "type": "object",
      "properties": {
        "synonyms": { "type": "array", "items": { "$ref": "#/$defs/SemanticRelation" } },
        "antonyms": { "type": "array", "items": { "$ref": "#/$defs/SemanticRelation" } },
        "hypernyms": { "type": "array", "items": { "$ref": "#/$defs/SemanticRelation" } },
        "hyponyms": { "type": "array", "items": { "$ref": "#/$defs/SemanticRelation" } },
        "coordinate_terms": {
          "type": "array",
          "items": { "$ref": "#/$defs/SemanticRelation" },
          "description": "Peer-level terms (e.g. days of the week together)."
        },
        "holonyms": {
          "type": "array",
          "items": { "$ref": "#/$defs/SemanticRelation" },
          "description": "Wholes that contain this term as a part."
        },
        "meronyms": {
          "type": "array",
          "items": { "$ref": "#/$defs/SemanticRelation" },
          "description": "Parts that make up this term."
        },
        "troponyms": {
          "type": "array",
          "items": { "$ref": "#/$defs/SemanticRelation" },
          "description": "For verbs: manner-of-action subtypes."
        },
        "comeronyms": {
          "type": "array",
          "items": { "$ref": "#/$defs/SemanticRelation" },
          "description": "Terms in the same semantic field (complementary/contrastive); Wiktionary Comeronyms section."
        },
        "parasynonyms": {
          "type": "array",
          "items": { "$ref": "#/$defs/SemanticRelation" },
          "description": "Near-synonyms with distinct nuance; Wiktionary Parasynonyms section."
        },
        "collocations": {
          "type": "array",
          "items": { "$ref": "#/$defs/SemanticRelation" },
          "description": "Typical word combinations; Wiktionary Collocations section."
        }
      },
      "additionalProperties": false
    },
    "EtymologyLink": {
      "type": "object",
      "required": ["template", "relation", "source_lang", "raw"],
      "properties": {
        "template": { "type": "string", "description": "Template name, e.g. 'inh', 'der', 'bor', 'cog'" },
        "relation": {
          "type": "string",
          "description": "The semantic relation between the target and source language forms. Typically 'inherited', 'borrowed', 'derived', or 'cognate'.",
          "examples": ["inherited", "borrowed", "derived", "cognate"]
        },
        "source_lang": { "type": "string" },
        "source_lang_name": { "type": "string" },
        "term": { "type": "string" },
        "gloss": { "type": "string" },
        "raw": { "type": "string" }
      },
      "additionalProperties": false
    },
    "EtymologyData": {
      "type": "object",
      "properties": {
        "chain": {
          "type": "array",
          "items": { "$ref": "#/$defs/EtymologyLink" },
          "description": "Ordered ancestry chain: inherited (inh), derived (der), borrowed (bor) links."
        },
        "cognates": {
          "type": "array",
          "items": { "$ref": "#/$defs/EtymologyLink" },
          "description": "Cognate forms in other languages (from {{cog}} templates), distinct from the ancestry chain."
        },
        "raw_text": {
          "type": "string",
          "description": "Full human-readable prose of the etymology section, wikimarkup stripped."
        }
      },
      "additionalProperties": false
    },
    "SectionLinkItem": {
      "type": "object",
      "required": ["term", "lang", "template", "raw"],
      "properties": {
        "term": { "type": "string" },
        "lang": { "type": "string" },
        "gloss": { "type": "string" },
        "alt": { "type": "string" },
        "template": { "type": "string" },
        "raw": { "type": "string" }
      },
      "additionalProperties": false
    },
    "SectionWithLinks": {
      "type": "object",
      "required": ["raw_text", "items"],
      "properties": {
        "raw_text": { "type": "string", "description": "Verbatim section content" },
        "items": { "type": "array", "items": { "$ref": "#/$defs/SectionLinkItem" } }
      },
      "additionalProperties": false
    },
    "InflectionTable": {
      "type": "object",
      "description": "A hierarchical representation of a grammatical paradigm. Keys are dimensions (e.g. 'mood', 'tense'), values are either strings, arrays of strings, or nested InflectionTable objects.",
      "additionalProperties": {
        "anyOf": [
          { "type": "string" },
          { "type": "array", "items": { "type": "string" } },
          { "$ref": "#/$defs/InflectionTable" }
        ]
      }
    },
    "RichEntry": {
      "type": "object",
      "required": ["headword", "pos", "source"],
      "properties": {
        "headword": { "type": "string" },
        "pos": { "type": "string" },
        "type": { "$ref": "#/$defs/LexemeType" },
        "form_of": { "$ref": "#/$defs/FormOf" },
        "morphology": { "type": "object", "additionalProperties": true },
        "pronunciation": { "$ref": "#/$defs/Pronunciation" },
        "hyphenation": { "$ref": "#/$defs/Hyphenation" },
        "etymology": { "type": "array", "items": { "type": "object" } },
        "senses": { "type": "array", "items": { "$ref": "#/$defs/Sense" } },
        "relations": { "$ref": "#/$defs/SemanticRelations" },
        "derived_terms": { "$ref": "#/$defs/SectionWithLinks" },
        "related_terms": { "$ref": "#/$defs/SectionWithLinks" },
        "descendants": { "$ref": "#/$defs/SectionWithLinks" },
        "usage_notes": { "type": "array", "items": { "type": "string" } },
        "references": { "type": "array", "items": { "type": "string" } },
        "inflection_table": { "$ref": "#/$defs/InflectionTable" },
        "translations": { "type": "object", "additionalProperties": { "type": "array", "items": {} } },
        "wikidata": { "$ref": "#/$defs/WikidataEnrichment" },
        "source": { "$ref": "#/$defs/WiktionarySource" }
      },
      "additionalProperties": true
    },
    "Lexeme": {
      "type": "object",
      "required": [
        "id", "language", "query", "type", "form",
        "etymology_index", "part_of_speech_heading",
        "lexicographic_section", "lexicographic_family",
        "templates", "source"
      ],
      "properties": {
        "id": { "type": "string" },
        "language": { "$ref": "#/$defs/WikiLang" },
        "query": { "type": "string" },
        "type": { "$ref": "#/$defs/LexemeType" },
        "form": { "type": "string" },
        "etymology_index": { "type": "integer", "minimum": 0 },
        "part_of_speech_heading": { "type": "string" },
        "lexicographic_section": {
          "type": "string",
          "description": "Stable slug for the section kind (verb, suffix, han_character, …)."
        },
        "lexicographic_family": { "$ref": "#/$defs/LexicographicFamily" },
        "part_of_speech": {
          "description": "Strict grammatical PoS when applicable; null for morphemes, symbols, phraseology, etc.",
          "anyOf": [{ "type": "null" }, { "$ref": "#/$defs/PartOfSpeech" }]
        },
        "pronunciation": { "$ref": "#/$defs/Pronunciation" },
        "hyphenation": { "$ref": "#/$defs/Hyphenation" },
        "form_of": { "$ref": "#/$defs/FormOf" },
        "translations": {
          "type": "object",
          "additionalProperties": { "type": "array", "items": { "$ref": "#/$defs/TranslationItem" } }
        },
        "templates": {
          "type": "object",
          "additionalProperties": { "type": "array", "items": { "$ref": "#/$defs/StoredTemplate" } }
        },
        "templates_all": {
          "type": "array",
          "items": { "$ref": "#/$defs/StoredTemplateInstance" },
          "description": "Templates in document order with optional location metadata"
        },
        "senses": { "type": "array", "items": { "$ref": "#/$defs/Sense" } },
        "semantic_relations": { "$ref": "#/$defs/SemanticRelations" },
        "etymology": { "$ref": "#/$defs/EtymologyData" },
        "derived_terms": { "$ref": "#/$defs/SectionWithLinks" },
        "related_terms": { "$ref": "#/$defs/SectionWithLinks" },
        "descendants": { "$ref": "#/$defs/SectionWithLinks" },
        "usage_notes": { "type": "array", "items": { "type": "string" } },
        "headword_morphology": {
          "$ref": "#/$defs/HeadwordMorphology"
        },
        "alternative_forms": {
          "type": "array",
          "items": { "$ref": "#/$defs/AlternativeForm" },
          "description": "Entries from the ====Alternative forms==== section."
        },
        "see_also": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Terms from the ====See also==== section."
        },
        "anagrams": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Anagrams of this word from the ====Anagrams==== section."
        },
        "references": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Content from the ====References==== section."
        },
        "inflection_table_ref": {
          "type": "object",
          "properties": {
            "template_name": { "type": "string" },
            "raw": { "type": "string" }
          },
          "required": ["template_name", "raw"],
          "additionalProperties": false,
          "description": "Reference to the inflection template used."
        },
        "external_links": {
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "description": "All external links extracted from the page."
        },
        "page_links": {
          "type": "array",
          "items": { "type": "string" },
          "description": "All Wiktionary page titles linked from this article."
        },
        "images": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of image filenames/URLs found on the page."
        },
        "wikidata": { "$ref": "#/$defs/WikidataEnrichment" },
        "resolved_for_query": { "type": "string" },
        "lemma_triggered_by_lexeme_id": { "type": "string" },
        "preferred": { "type": "boolean" },
        "source": {
          "type": "object",
          "required": ["wiktionary"],
          "properties": {
            "wiktionary": { "$ref": "#/$defs/WiktionarySource" }
          },
          "additionalProperties": false
        },
        "categories": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Wiktionary categories filtered to this language section."
        },
        "langlinks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["lang", "title"],
            "properties": {
              "lang": { "type": "string" },
              "title": { "type": "string" }
            },
            "additionalProperties": false
          },
          "description": "Links to the same term in other Wiktionary language editions."
        },
        "metadata": {
          "type": "object",
          "description": "Page-level metadata from the MediaWiki API.",
          "properties": {
            "last_modified": { "type": "string", "format": "date-time" },
            "length": { "type": "integer" },
            "pageid": { "type": ["integer", "null"] },
            "lastrevid": { "type": "integer" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "properties": {
    "schema_version": { "$ref": "#/$defs/schemaVersion" },
    "rawLanguageBlock": { "type": "string" },
    "lexemes": {
      "type": "array",
      "items": { "$ref": "#/$defs/Lexeme" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "debug": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "decoderId": { "type": "string" },
            "matchedTemplates": { "type": "array", "items": { "type": "object" } },
            "fieldsProduced": { "type": "array", "items": { "type": "string" } }
          }
        }
      },
      "description": "Detailed trace of decoder matches per lexeme. Primarily for engine developers."
    },
    "metadata": {
      "type": "object",
      "description": "Page-level metadata attached to the FetchResult.",
      "properties": {
        "categories": { "type": "array", "items": { "type": "string" } },
        "langlinks": { "type": "array", "items": {} },
        "info": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": true
    }
  },
  "required": ["rawLanguageBlock", "lexemes", "notes"]
}